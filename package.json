{
  "name": "@lendworks/lendiq",
  "version": "1.4.0",
  "description": "Official TypeScript SDK for the LendIQ API — AI-powered MCA underwriting platform",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./webhooks": {
      "import": {
        "types": "./dist/webhooks.d.ts",
        "default": "./dist/webhooks.js"
      },
      "require": {
        "types": "./dist/webhooks.d.cts",
        "default": "./dist/webhooks.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "homepage": "https://docs.iq.lend.works/sdk/typescript",
  "repository": {
    "type": "git",
    "url": "https://github.com/thornebridge/lendiq-node"
  },
  "bugs": {
    "url": "https://github.com/thornebridge/lendiq-node/issues"
  },
  "keywords": [
    "lendiq",
    "mca",
    "underwriting",
    "bank-statement",
    "fintech",
    "api",
    "sdk"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:ci": "vitest run",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
